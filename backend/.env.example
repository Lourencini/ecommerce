# =============================================
# Variáveis de Ambiente — Backend NestJS
# =============================================
# Copie para .env e ajuste os valores

# ── Banco de Dados ────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ecommerce3d?schema=public"

# ── Aplicação ─────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ── Frete / Transportadora ────────────────────
# Correios / Melhor Envio (preencher no Step 2)
SHIPPING_API_URL=
SHIPPING_API_KEY=
SHIPPING_ZIP_ORIGIN=01310100

# ── Segurança ─────────────────────────────────
JWT_SECRET=TROQUE_POR_32_CHARS_ALEATORIO_AQUI
JWT_EXPIRATION=7d

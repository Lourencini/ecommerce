// ============================================================
// Prisma Schema — E-commerce 3D Print
// Convenções:
//   - Tabelas no plural (@@map)
//   - Modelos no singular
//   - UUIDs para IDs de pedidos e produtos (anti-IDOR)
//   - Preços como Decimal(19,4) (anti-arredondamento)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USUÁRIO (Auth)
// Separado de Customer: User autentica, Customer tem dados de compra
// ============================================================
model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  name         String   @db.VarChar(255)
  role         UserRole @default(CUSTOMER)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  customer Customer?

  @@index([email])
  @@map("users")
}

enum UserRole {
  ADMIN
  CUSTOMER

  @@map("user_role")
}

// ============================================================
// CATEGORIAS DE PRODUTOS
// ============================================================
model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(100)
  slug        String    @unique @db.VarChar(100)
  description String?   @db.Text
  imageUrl    String?   @map("image_url") @db.VarChar(500)
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  products Product[]

  @@map("categories")
}

// ============================================================
// PRODUTOS
// UUID para anti-IDOR (evita enumeração sequencial)
// Decimal(19,4) para precisão de preços
// ============================================================
model Product {
  id             String    @id @default(uuid()) @db.Uuid
  sku            String    @unique @db.VarChar(50)
  name           String    @db.VarChar(255)
  slug           String    @unique @db.VarChar(300)
  description    String?   @db.Text
  priceInCents   Decimal   @map("price") @db.Decimal(19, 4)
  compareAtPrice Decimal?  @map("compare_at_price") @db.Decimal(19, 4)
  // Dimensões para cálculo de frete
  weightGrams    Int       @map("weight_grams")
  lengthCm       Decimal   @map("length_cm") @db.Decimal(8, 2)
  widthCm        Decimal   @map("width_cm") @db.Decimal(8, 2)
  heightCm       Decimal   @map("height_cm") @db.Decimal(8, 2)
  // Estoque
  stockQuantity  Int       @default(0) @map("stock_quantity")
  isActive       Boolean   @default(true) @map("is_active")
  isFeatured     Boolean   @default(false) @map("is_featured")
  // Material de impressão 3D
  material       String?   @db.VarChar(50)
  filamentType   String?   @map("filament_type") @db.VarChar(50)
  filamentColor  String?   @map("filament_color") @db.VarChar(50)
  printHours     Decimal?  @map("print_hours") @db.Decimal(6, 2)
  imageUrls      String[]  @map("image_urls")
  // Relações
  categoryId     Int?      @map("category_id")
  category       Category? @relation(fields: [categoryId], references: [id])
  orderItems     OrderItem[]
  reviews        Review[]
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([categoryId])
  @@index([isActive])
  @@index([sku])
  @@index([slug])
  @@map("products")
}

// ============================================================
// CLIENTES
// Vinculado ao User para autenticação
// ============================================================
model Customer {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @unique @map("user_id") @db.Uuid
  user      User?    @relation(fields: [userId], references: [id])
  name      String   @db.VarChar(255)
  email     String   @unique @db.VarChar(255)
  phone     String?  @db.VarChar(20)
  document  String?  @db.VarChar(14) // CPF/CNPJ
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orders    Order[]
  addresses Address[]
  reviews   Review[]

  @@index([email])
  @@index([userId])
  @@map("customers")
}

// ============================================================
// ENDEREÇOS
// ============================================================
model Address {
  id           Int      @id @default(autoincrement())
  customerId   String   @map("customer_id") @db.Uuid
  customer     Customer @relation(fields: [customerId], references: [id])
  label        String?  @db.VarChar(50) // "Casa", "Trabalho"
  street       String   @db.VarChar(255)
  number       String   @db.VarChar(20)
  complement   String?  @db.VarChar(100)
  neighborhood String   @db.VarChar(100)
  city         String   @db.VarChar(100)
  state        String   @db.Char(2)
  zipCode      String   @map("zip_code") @db.VarChar(9)
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at")

  orders Order[]

  @@index([customerId])
  @@map("addresses")
}

// ============================================================
// PEDIDOS
// UUID para anti-IDOR (não revela volume de vendas)
// ============================================================
model Order {
  id               String        @id @default(uuid()) @db.Uuid
  orderNumber      String        @unique @map("order_number")
  customerId       String        @map("customer_id") @db.Uuid
  customer         Customer      @relation(fields: [customerId], references: [id])
  addressId        Int?          @map("address_id")
  address          Address?      @relation(fields: [addressId], references: [id])
  status           OrderStatus   @default(PENDING)
  // Pagamento
  paymentStatus    PaymentStatus @default(PENDING) @map("payment_status")
  paymentMethod    String?       @map("payment_method") @db.VarChar(50)
  paymentIntentId  String?       @map("payment_intent_id") @db.VarChar(255)
  // Valores com alta precisão
  totalShipping    Decimal       @map("total_shipping") @db.Decimal(19, 4)
  totalProducts    Decimal       @map("total_products") @db.Decimal(19, 4)
  discount         Decimal       @default(0) @db.Decimal(19, 4)
  total            Decimal       @db.Decimal(19, 4)
  // Dados de frete
  shippingService  String?       @map("shipping_service") @db.VarChar(100)
  trackingCode     String?       @map("tracking_code") @db.VarChar(100)
  // KPI: Cycle Time
  orderedAt         DateTime     @default(now()) @map("ordered_at")
  printingStartedAt DateTime?    @map("printing_started_at")
  shippedAt         DateTime?    @map("shipped_at")
  deliveredAt       DateTime?    @map("delivered_at")
  cancelledAt       DateTime?    @map("cancelled_at")
  notes            String?       @db.Text
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  items          OrderItem[]
  shippingQuotes ShippingQuote[]
  statusHistory  OrderStatusHistory[]

  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([orderedAt])
  @@map("orders")
}

// ============================================================
// ITENS DO PEDIDO
// ============================================================
model OrderItem {
  id          Int     @id @default(autoincrement())
  orderId     String  @map("order_id") @db.Uuid
  order       Order   @relation(fields: [orderId], references: [id])
  productId   String  @map("product_id") @db.Uuid
  product     Product @relation(fields: [productId], references: [id])
  quantity    Int
  unitPrice   Decimal @map("unit_price") @db.Decimal(19, 4)
  totalPrice  Decimal @map("total_price") @db.Decimal(19, 4)
  productName String  @map("product_name") @db.VarChar(255)
  productSku  String  @map("product_sku") @db.VarChar(50)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// ============================================================
// HISTÓRICO DE STATUS (Audit Trail)
// ============================================================
model OrderStatusHistory {
  id         Int          @id @default(autoincrement())
  orderId    String       @map("order_id") @db.Uuid
  order      Order        @relation(fields: [orderId], references: [id])
  fromStatus OrderStatus? @map("from_status")
  toStatus   OrderStatus  @map("to_status")
  note       String?      @db.Text
  createdAt  DateTime     @default(now()) @map("created_at")

  @@index([orderId])
  @@map("order_status_history")
}

// ============================================================
// COTAÇÕES DE FRETE
// ============================================================
model ShippingQuote {
  id            Int      @id @default(autoincrement())
  orderId       String?  @map("order_id") @db.Uuid
  order         Order?   @relation(fields: [orderId], references: [id])
  zipCodeOrigin String   @map("zip_code_origin") @db.VarChar(9)
  zipCodeDest   String   @map("zip_code_dest") @db.VarChar(9)
  weightGrams   Int      @map("weight_grams")
  lengthCm      Decimal  @map("length_cm") @db.Decimal(8, 2)
  widthCm       Decimal  @map("width_cm") @db.Decimal(8, 2)
  heightCm      Decimal  @map("height_cm") @db.Decimal(8, 2)
  price         Decimal  @db.Decimal(19, 4)
  deadline      Int
  serviceName   String   @map("service_name") @db.VarChar(100)
  carrier       String   @db.VarChar(100)
  expiresAt     DateTime @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([orderId])
  @@index([zipCodeDest])
  @@map("shipping_quotes")
}

// ============================================================
// AVALIAÇÕES
// ============================================================
model Review {
  id         Int      @id @default(autoincrement())
  productId  String   @map("product_id") @db.Uuid
  product    Product  @relation(fields: [productId], references: [id])
  customerId String   @map("customer_id") @db.Uuid
  customer   Customer @relation(fields: [customerId], references: [id])
  rating     Int      // 1 a 5
  comment    String?  @db.Text
  isApproved Boolean  @default(false) @map("is_approved")
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([productId, customerId])
  @@index([productId])
  @@index([customerId])
  @@map("reviews")
}

// ============================================================
// ENUMS
// ============================================================
enum OrderStatus {
  PENDING
  CONFIRMED
  PRINTING
  READY
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED

  @@map("order_status")
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED

  @@map("payment_status")
}

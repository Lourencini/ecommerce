# ============================================================
# Backend — E-commerce 3D Print
# Copie este arquivo para .env e preencha os valores
# ============================================================

# Banco de Dados (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ecommerce3d?schema=public"

# Aplicação
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001/api/v1

# Autenticação JWT
JWT_SECRET="TROQUE-POR-32-CHARS-ALEATORIO-AQUI"
JWT_EXPIRES_IN="7d"

# Frete (Correios / Melhor Envio)
SHIPPING_ZIP_ORIGIN=01310100
SHIPPING_API_URL=
SHIPPING_API_KEY=

# MercadoPago
# TEST: https://developers.mercadopago.com
MERCADOPAGO_ACCESS_TOKEN="TEST-xxxxxxxxxxxxxxxxxxxxx"
MERCADOPAGO_WEBHOOK_SECRET="seu-webhook-secret"

# E-mail (Resend — https://resend.com, plano grátis)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="E-3D Print <noreply@seudominio.com.br>"

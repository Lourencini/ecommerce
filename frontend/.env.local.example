# ============================================================
# Frontend — E-commerce 3D Print
# Copie para .env.local e preencha os valores
# ============================================================

# URL do backend (sem barra no final)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# URL do site em produção (para SEO e sitemap)
NEXT_PUBLIC_SITE_URL=https://seudominio.com.br

# NextAuth (obrigatório em produção — gere com: openssl rand -base64 32)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET="GERE-COM-openssl-rand-base64-32"
